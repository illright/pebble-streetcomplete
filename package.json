{
  "name": "pebble-streetcomplete",
  "author": "illright",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "pebble": {
    "displayName": "pebble-streetcomplete",
    "uuid": "1da944ed-33e5-47e0-9ae2-72ca3a58b1e3",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": {
      "Cmd": 0,
      "QuestQuestion": 3,
      "QuestDistM": 4,
      "QuestTypeId": 5,
      "QuestElementId": 6,
      "QuestElementType": 7,
      "QuestName": 8,
      "AnswerValue": 9,
      "QuestAnswerOptions": 10,
      "QuestBearing": 11,
      "Arrived": 12,
      "SkipType": 13,
      "QuestNodeLatE6": 14,
      "QuestNodeLonE6": 15,
      "UserLatE6": 16,
      "UserLonE6": 17,
      "MapData": 18
    },
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "ICON_CHECKMARK",
          "file": "images/action_bar_icon_check.png"
        },
        {
          "type": "png",
          "name": "ICON_CROSS",
          "file": "images/action_bar_icon_dismiss.png"
        },
        {
          "type": "png",
          "name": "ICON_ELLIPSIS",
          "file": "images/music_icon_ellipsis.png"
        },
        {
          "type": "png",
          "name": "ICON_PLUS",
          "file": "images/action_bar_icon_plus.png"
        },
        {
          "type": "png",
          "name": "ICON_MINUS",
          "file": "images/action_bar_icon_minus.png"
        },
        {
          "type": "png",
          "name": "ICON_RETRY",
          "file": "images/action_bar_icon_retry.png"
        }
      ]
    }
  },
  "devDependencies": {
    "@blazediff/core-native": "^4.2.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "test:e2e:emery": "PEBBLE_PLATFORM=emery node --test --test-concurrency=1 test/e2e/**/*.test.js",
    "test:e2e:gabbro": "PEBBLE_PLATFORM=gabbro node --test --test-concurrency=1 test/e2e/**/*.test.js",
    "test:e2e:all": "pnpm run test:e2e:emery && pnpm run test:e2e:gabbro",
    "test:e2e:update:emery": "UPDATE_BASELINES=1 PEBBLE_PLATFORM=emery node --test --test-concurrency=1 test/e2e/**/*.test.js",
    "test:e2e:update:gabbro": "UPDATE_BASELINES=1 PEBBLE_PLATFORM=gabbro node --test --test-concurrency=1 test/e2e/**/*.test.js",
    "test:e2e:update": "npm run test:e2e:update:emery && npm run test:e2e:update:gabbro",
    "format": "prettier --write ."
  }
}
